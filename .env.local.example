# Supabase Dashboard → Project Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# username → 합성 이메일 도메인 (변경 시 기존 계정 로그인 불가)
NEXT_PUBLIC_USERNAME_EMAIL_DOMAIN=lms.siwon.local

# Supabase 서비스 롤 키 (관리자가 직접 회원/강사 계정을 생성할 때만 사용).
# 매우 민감 — 절대 클라이언트에 노출하지 말 것. 서버에서만 사용됨.
# Supabase Dashboard → Project Settings → API → service_role secret 복사.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
